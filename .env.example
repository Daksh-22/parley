# Copy to .env and adjust. Every variable here is validated at boot in
# apps/server/src/config/env.ts. The server refuses to start with missing or
# invalid configuration.

# --- Server ---
NODE_ENV=development
PORT=4000

# --- Datastores ---
MONGO_URI=mongodb://127.0.0.1:27017/parley
REDIS_URL=redis://127.0.0.1:6379

# --- Auth ---
# Generate real values with: openssl rand -hex 32
# Minimum 32 characters, never reuse between access and refresh.
JWT_ACCESS_SECRET=replace-me-with-openssl-rand-hex-32-output
JWT_REFRESH_SECRET=replace-me-with-a-different-openssl-rand-value
# Access tokens are short lived, refresh tokens rotate via httpOnly cookie.
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600

# --- Web ---
# The exact origin the browser app is served from. CORS is locked to this.
CORS_ORIGIN=http://localhost:5173

# --- Logging ---
# one of: trace, debug, info, warn, error
LOG_LEVEL=info

# --- AI memory layer (optional; chat works fully without it) ---
# The mock provider is deterministic and needs no keys: ideal for local dev.
AI_ENABLED=false
# mock | anthropic | openai
AI_CHAT_PROVIDER=mock
# mock | openai
AI_EMBED_PROVIDER=mock
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# AI_CHAT_MODEL=claude-haiku-4-5-20251001
# AI_EMBED_MODEL=text-embedding-3-small
# AI_EMBED_DIMENSIONS=1536
QDRANT_URL=http://127.0.0.1:6333
# QDRANT_COLLECTION=parley-memory
# AI_CONTEXT_TOKEN_BUDGET=4000
# AI_ANSWER_MAX_TOKENS=700
# AI_DAILY_TOKEN_QUOTA=200000
# AI_CACHE_TTL_SECONDS=86400
# AI_TIMEOUT_MS=30000
# RERANK_ENABLED=false

# --- Rate limits (optional, sensible defaults shown) ---
# Sliding window with a temporary mute on violation. Auth limit is requests
# per minute per IP on /auth routes.
# AUTH_RATE_LIMIT=30
# MSG_RATE_LIMIT=10
# MSG_RATE_WINDOW_MS=10000
# MSG_MUTE_SECONDS=10
# JOIN_RATE_LIMIT=15
# JOIN_RATE_WINDOW_MS=10000
# JOIN_MUTE_SECONDS=5
# CONN_RATE_LIMIT=30
# CONN_RATE_WINDOW_MS=60000
# CONN_MUTE_SECONDS=60

{
  "name": "parley",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "ai:backfill": "pnpm --filter @parley/server ai:backfill",
    "seed:demo": "pnpm --filter @parley/server seed:demo",
    "ai:export-feedback": "pnpm --filter @parley/server ai:export-feedback",
    "ai:eval": "pnpm --filter @parley/server ai:eval",
    "ai:metrics": "pnpm --filter @parley/server ai:metrics",
    "chaos": "tsx infra/chaos.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "lighthouse": "^13.4.0",
    "prettier": "^3.4.2",
    "puppeteer-core": "^25.1.0",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  }
}

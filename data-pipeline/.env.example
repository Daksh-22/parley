# Parley data platform — copy to .env and adjust.
# Mirrors the Node app's config style (apps/server/.env). All paths are
# relative to the data-pipeline/ directory unless absolute.

# --- Source: the same MongoDB the Parley server writes to ---
# Local dev (docker compose up -d in the repo root) uses this default.
# For MongoDB Atlas, paste your SRV string here.
MONGO_URI=mongodb://127.0.0.1:27017/parley
MONGO_DB=parley

# --- Lakehouse layout (local Parquet by default) ---
# bronze = raw 1:1 extract, gold = curated star schema.
DATA_DIR=./data
BRONZE_DIR=./data/bronze
GOLD_DIR=./data/gold

# --- Incremental extraction ---
# The extractor watermarks on updatedAt. State is stored in this file so each
# run only pulls documents changed since the last successful run.
WATERMARK_FILE=./data/_state/watermark.json
# Set to true to ignore the watermark and re-extract everything.
FULL_REFRESH=false

# --- Privacy ---
# When false (default) raw message bodies and AI question/answer text are NOT
# carried into the gold layer — only derived metrics (length, word count).
# This keeps the warehouse free of conversation content, matching Parley's
# per-room memory stance. Flip to true only if your governance policy allows it.
INCLUDE_MESSAGE_TEXT=false

# --- Warehouse target ---
# WAREHOUSE_TARGET = snowflake | duckdb
# duckdb runs fully locally (no account needed) and is the default so the
# whole pipeline is demoable end to end. Switch to snowflake in production.
WAREHOUSE_TARGET=duckdb
DUCKDB_PATH=./data/warehouse.duckdb

# --- Snowflake (only used when WAREHOUSE_TARGET=snowflake) ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=PARLEY_WH
SNOWFLAKE_DATABASE=PARLEY
SNOWFLAKE_SCHEMA=ANALYTICS

# --- Spark ---
# local[*] uses every core on this machine. Point at a cluster master
# (e.g. spark://localhost:7077) to use the docker-compose Spark cluster.
SPARK_MASTER=local[*]
SPARK_APP_NAME=parley-transform
